PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ticket-sys
ALLOWED_ORIGIN=https://your-frontend-domain.com

# End-of-Day Report (comma-separated list of recipient emails)
EOD_REPORT_RECIPIENTS=admin@example.com,finance@example.com

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@globalhoops.com

# Semaphore SMS
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=GlobalHoops

# Maya Payment
MAYA_PUBLIC_KEY=pk-your-maya-public-key-here
MAYA_SECRET_KEY=sk-your-maya-secret-key-here
MAYA_BASE_URL=https://pg-sandbox.paymaya.com
MAYA_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:3001
