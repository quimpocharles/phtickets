PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ticket-sys
ALLOWED_ORIGIN=https://your-frontend-domain.com

# End-of-Day Report (comma-separated list of recipient emails)
EOD_REPORT_RECIPIENTS=admin@example.com,finance@example.com

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@globalhoops.com

# Semaphore SMS
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=GlobalHoops

# PayMongo
PAYMONGO_SECRET_KEY=sk_test_your-key-here
PAYMONGO_WEBHOOK_SECRET=whsk_your-webhook-secret-here
APP_BASE_URL=http://localhost:3001

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
